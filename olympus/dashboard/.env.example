# CERES OS Dashboard Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# Vehicle API URL (default: http://localhost:3001)
REACT_APP_VEHICLE_API_URL=http://localhost:3001

# API authentication key (must match CERES_API_KEY on the Vehicle API server)
# Leave empty for dev mode (no auth required when API has no key set either)
REACT_APP_CERES_API_KEY=

# Cesium Ion access token (optional, for terrain/imagery)
REACT_APP_CESIUM_ION_TOKEN=
