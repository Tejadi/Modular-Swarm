# /etc/default/swarm-node -- swarm Jetson autostart config.
# Copy to /etc/default/swarm-node (the installer does this) and edit per module.

# Role: auto = detect from the nRF (leader/gateway nRF advertises it); or force
# leader | member when you want to pin it.
SWARM_ROLE=auto

# nRF serial device: auto = first /dev/ttyACM*, or an explicit path.
SWARM_NRF_PORT=auto

# Command-station services (zenoh REST + vehicle-api). On a self-contained
# leader these are localhost; members point at the leader's address.
SWARM_ZENOH_REST=http://localhost:8000
SWARM_VEHICLE_API=http://localhost:3001
SWARM_KEY_PREFIX=ceres
SWARM_SINK=rest

# Leader map anchor used until GPS lock (decimal degrees).
SWARM_STATION_LAT=39.9526
SWARM_STATION_LON=-75.1652

# --- scouts only (swarm-perception.service) ---
# YOLO model path; relative paths resolve against the repo (WorkingDirectory).
SWARM_YOLO_ONNX=yolov8n.onnx
# Label for published detections; if it is the node's EUI, perception will poll
# that node's live telemetry for pose so detection geo tracks the moving scout.
SWARM_NODE_EUI=
